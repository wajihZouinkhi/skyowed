{
  "name": "skyowed",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:mobile": "cross-env BUILD_TARGET=mobile npm run build:mobile:inner",
    "build:mobile:inner": "node scripts/mobile-prebuild.js && next build && node scripts/mobile-postbuild.js",
    "start": "next start",
    "lint": "next lint",
    "test": "npx tsx --test src/lib/eligibility.test.ts src/lib/airlines.test.ts",
    "cap:sync": "npm run build:mobile && npx cap sync",
    "cap:ios": "npm run build:mobile && npx cap sync ios && npx cap open ios",
    "cap:android": "npm run build:mobile && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@capacitor-community/file-opener": "^8.0.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "next": "^14.2.35",
    "pdf-lib": "^1.17.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "@types/node": "20.12.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "cross-env": "^10.1.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.4",
    "tsx": "^4.19.0",
    "typescript": "5.4.5"
  }
}
